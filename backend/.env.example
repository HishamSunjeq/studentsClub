# App
APP_ENV=development
SECRET_KEY=change-me-use-at-least-32-random-characters-here
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://studentsclub:dev@localhost:5432/studentsclub

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Object storage (MinIO for dev)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=studentsclub-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345

# AI
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Limits
MAX_UPLOAD_BYTES=52428800
DAILY_UPLOAD_LIMIT_PER_USER=10

# CORS
CORS_ORIGINS=http://localhost:5173

# Password reset
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# SMTP (leave blank in dev to log reset link instead of sending email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@studentsclub.local
