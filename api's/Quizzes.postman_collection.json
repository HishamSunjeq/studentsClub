{
  "info": {
    "_postman_id": "a1b2c3d4-0008-4000-8000-000000000008",
    "name": "Quizzes",
    "description": "Quiz session endpoints — start, browse, answer questions, and complete a quiz.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Start Quiz",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json.id) {",
              "  pm.environment.set('quiz_session_id', json.id);",
              "}",
              "if (json.questions && json.questions.length > 0) {",
              "  const q = json.questions[0];",
              "  pm.environment.set('question_id', q.id);",
              "  if (q.choices && q.choices.length > 0) {",
              "    pm.environment.set('choice_id', q.choices[0].id);",
              "  }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"subject_id\": \"{{subject_id}}\",\n  \"count\": 10\n}"
        },
        "url": {
          "raw": "{{base_url}}/quizzes",
          "host": ["{{base_url}}"],
          "path": ["quizzes"]
        },
        "description": "Create and start a new quiz session for a subject.\n\n**Requires:** Bearer token\n\n**Body fields:**\n- `subject_id` — UUID of the subject\n- `count` — number of questions to draw (1–50, default 10)\n\n**Returns:** `QuizSessionWithQuestionsResponse` (201) — includes shuffled questions with choices (correct answer hidden)"
      },
      "response": []
    },
    {
      "name": "List My Quizzes",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/quizzes/me?page=1&size=20",
          "host": ["{{base_url}}"],
          "path": ["quizzes", "me"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "size", "value": "20", "description": "Max 100" }
          ]
        },
        "description": "List all quiz sessions for the authenticated user.\n\n**Requires:** Bearer token\n\n**Query params:**\n- `page` — default 1\n- `size` — default 20, max 100\n\n**Returns:** `QuizSessionListResponse` (200)"
      },
      "response": []
    },
    {
      "name": "Get Quiz Session",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/quizzes/{{quiz_session_id}}",
          "host": ["{{base_url}}"],
          "path": ["quizzes", "{{quiz_session_id}}"]
        },
        "description": "Retrieve a quiz session's summary (without questions).\n\n**Requires:** Bearer token\n\n**Path params:**\n- `quiz_session_id` — UUID\n\n**Returns:** `QuizSessionResponse` (200)"
      },
      "response": []
    },
    {
      "name": "Get Quiz Session with Questions",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/quizzes/{{quiz_session_id}}/questions",
          "host": ["{{base_url}}"],
          "path": ["quizzes", "{{quiz_session_id}}", "questions"]
        },
        "description": "Retrieve a quiz session along with all its questions, choices, and the IDs of already-answered questions.\n\n**Requires:** Bearer token\n\n**Path params:**\n- `quiz_session_id` — UUID\n\n**Returns:** `QuizSessionWithQuestionsResponse` (200)"
      },
      "response": []
    },
    {
      "name": "Submit Answer",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question_id\": \"{{question_id}}\",\n  \"choice_id\": \"{{choice_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/quizzes/{{quiz_session_id}}/answer",
          "host": ["{{base_url}}"],
          "path": ["quizzes", "{{quiz_session_id}}", "answer"]
        },
        "description": "Submit an answer for one question in a quiz session.\n\n**Requires:** Bearer token\n\n**Path params:**\n- `quiz_session_id` — UUID\n\n**Body fields:**\n- `question_id` — UUID of the question being answered\n- `choice_id` — UUID of the selected choice\n\n**Returns:** `QuizAnswerResponse` (200) — reveals `is_correct`, `correct_choice_id`, `explanation`, running `score`"
      },
      "response": []
    },
    {
      "name": "Complete Quiz",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/quizzes/{{quiz_session_id}}/complete",
          "host": ["{{base_url}}"],
          "path": ["quizzes", "{{quiz_session_id}}", "complete"]
        },
        "description": "Mark a quiz session as completed. Call this after submitting all answers.\n\n**Requires:** Bearer token\n\n**Path params:**\n- `quiz_session_id` — UUID\n\n**Returns:** `QuizSessionResponse` (200) with final `score` and `completed_at`"
      },
      "response": []
    }
  ]
}
