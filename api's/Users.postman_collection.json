{
  "info": {
    "_postman_id": "a1b2c3d4-0003-4000-8000-000000000003",
    "name": "Users",
    "description": "User profile endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Current User",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/me",
          "host": ["{{base_url}}"],
          "path": ["users", "me"]
        },
        "description": "Return the profile of the authenticated user.\n\n**Requires:** Bearer token\n\n**Returns:** `UserResponse` (200)"
      },
      "response": []
    }
  ]
}
