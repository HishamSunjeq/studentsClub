{
  "info": {
    "_postman_id": "a1b2c3d4-4414-4000-8000-000000000000",
    "name": "Auth",
    "description": "Authentication endpoints — register, login, refresh, logout, change/forgot/reset password.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Change Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/change-password",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "change-password"
          ]
        },
        "description": "**Change Password**\n\n`operationId`: `auth_change_password`\n\n**Requires:** Bearer token (`access_token`).\n\n**Required body fields:** `current_password`, `new_password`\n\n**Body schema:** `ChangePasswordRequest`",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"current_password\": \"\",\n  \"new_password\": \"\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": []
    },
    {
      "name": "Forgot Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/forgot-password",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "forgot-password"
          ]
        },
        "description": "**Forgot Password**\n\n`operationId`: `auth_forgot_password`\n\n**Required body fields:** `email`\n\n**Body schema:** `ForgotPasswordRequest`",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"student@example.com\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": []
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "**Login**\n\n`operationId`: `auth_login`\n\n**Required body fields:** `email`, `password`\n\n**Body schema:** `LoginRequest`\n\n**Response schema:** `TokenResponse`",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.access_token) {",
              "  pm.environment.set('access_token', json.access_token);",
              "  pm.environment.set('refresh_token', json.refresh_token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
